# ══════════════════════════════════════════════════════════════════════════════
# TREBOR LABS — BACKEND ENVIRONMENT VARIABLES
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas .env al repositorio.
# ══════════════════════════════════════════════════════════════════════════════

# ─── Entorno ──────────────────────────────────────────────────────────────────
# "development" | "production"
NODE_ENV="development"

# ─── Base de datos ────────────────────────────────────────────────────────────
# Local (Docker): postgresql://trebor:trebor_secret@localhost:5432/treborlabs
# Railway:        agrega ?connection_limit=5&pool_timeout=10 al final
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/treborlabs"

# ─── Servidor ─────────────────────────────────────────────────────────────────
PORT=3001
BACKEND_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:5173"

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Genera uno seguro con:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Mínimo 32 caracteres. REQUERIDO en producción.
JWT_SECRET=""

# ─── Admin inicial ────────────────────────────────────────────────────────────
# Se crea/promueve automáticamente al iniciar el backend.
# Cambia la contraseña en producción.
ADMIN_EMAIL="admin@tudominio.com"
ADMIN_PASSWORD=""

# ─── OAuth: Google ────────────────────────────────────────────────────────────
# Obtén en: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: ${BACKEND_URL}/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── OAuth: GitHub ────────────────────────────────────────────────────────────
# Obtén en: https://github.com/settings/developers → OAuth Apps
# Authorization callback URL: ${BACKEND_URL}/auth/github/callback
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ─── MercadoPago ──────────────────────────────────────────────────────────────
# Obtén en: https://www.mercadopago.com.pe/developers/panel
# Usa el token de TEST para desarrollo, PRODUCCIÓN para live
MP_ACCESS_TOKEN=""

# ─── Email (Nodemailer via Gmail App Password) ────────────────────────────────
# Activa "Contraseñas de aplicación" en tu cuenta Google:
#   https://myaccount.google.com/apppasswords
# Formato app password: "xxxx xxxx xxxx xxxx" (con espacios)
GMAIL_USER=""
GMAIL_APP_PASSWORD=""
