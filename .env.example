# ─── Database ──────────────────────────────────────────────────────────────────
# Railway PostgreSQL — agrega ?connection_limit=5&pool_timeout=10 en producción
DATABASE_URL="postgresql://user:password@host:5432/treborlabs?connection_limit=5&pool_timeout=10"

# ─── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET="cambia-esto-por-un-secret-seguro-de-64-chars"

# ─── URLs ──────────────────────────────────────────────────────────────────────
BACKEND_URL="https://api.treborlabs.com"
FRONTEND_URL="https://treborlabs.com"
PORT=3001

# ─── Admin seed ────────────────────────────────────────────────────────────────
ADMIN_EMAIL="admin@treborlabs.com"
ADMIN_PASSWORD="CambiarEnProduccion123!"

# ─── OAuth: Google ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID="xxxxxxxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxxxxxxx"

# ─── OAuth: GitHub ─────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID="Iv1.xxxxxxxx"
GITHUB_CLIENT_SECRET="xxxxxxxx"

# ─── Email (Gmail App Password) ────────────────────────────────────────────────
GMAIL_USER="trebor@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# ─── MercadoPago ───────────────────────────────────────────────────────────────
MP_ACCESS_TOKEN="APP_USR-xxxxxxxx"

# ─── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV="production"
